    {
      "id": "etkg-WRqoiSd0jFmLzwUu",
      "type": "text",
      "x": 1198.1345567036892,
      "y": 987.2536291396791,
      "width": 4202.1337890625,
      "height": 6345,
      "angle": 0,
      "strokeColor": "#ffffff",
      "backgroundColor": "transparent",
